// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

enum PaymentStatus {
    Pending
    Paid
    Canceled
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    payments   Payment[] //Importante: agregé la relación bidireccional donde un socio
                        //tiene varios pagos, sirve para que prisma entienda la relación peor no agrega ninguna columna
    equipment_loans  EquipmentLoan[] // relación bidireccional, no agrega columna                    

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}

model Payment {
    id           String        @id @default(uuid())
    amount       Float
    month        Int
    year         Int
    status       PaymentStatus @default(Pending)
    due_date     DateTime      @db.Date
    payment_date DateTime?
    cancelled_at DateTime?
    member_id    String
    member       Member        @relation(fields: [member_id], references: [id])

    @@map("payments")
}

enum EquipmentLoanStatus {
    Loaned
    Returned
    Damaged
    Canceled
}

model EquipmentLoan {
    id           String              @id @default(uuid())
    item_name    String
    status       EquipmentLoanStatus @default(Loaned)
    loan_date    DateTime
    due_date     DateTime
    canceled_at  DateTime?
    member_id    String
    member       Member              @relation(fields: [member_id], references: [id])

    @@map("equipment_loans")
}
