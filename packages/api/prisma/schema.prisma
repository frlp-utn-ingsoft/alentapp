// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    medicalCertificates MedicalCertificate[]

    equipmentLoans EquipmentLoan[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}

feature/update-equipment-loan
model EquipmentLoan {
  id            String    @id @default(uuid())
  itemName      String    @map("item_name")
  status        String    // "Loaned", "Returned", "Damaged", "Canceled"
  isActive      Boolean   @default(true) @map("is_active")
  loanDate      DateTime  @default(now()) @map("loan_date")
  returnDate    DateTime? @map("return_date")
  canceledDate  DateTime? @map("canceled_date")
  notes         String?
  
  member        Member    @relation(fields: [memberId], references: [id])
  memberId      String    @map("member_id")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@index([memberId])
  @@index([status])
  @@index([isActive])
  @@map("equipment_loans")
}
=======

model MedicalCertificate {
  id            String    @id @default(uuid())
  memberId      String    @map("member_id")
  issueDate     DateTime  @map("issue_date") @db.Date
  expiryDate    DateTime  @map("expiry_date") @db.Date
  doctorLicense String    @map("doctor_license")
  isValidated   Boolean   @default(false) @map("is_validated")
  deletedAt     DateTime? @map("deleted_at")

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@map("medical_certificates")
}

enum LockerStatus {
  Available
  Occupied
  Maintenance
}

model Locker {
  id        String       @id @default(uuid())
  number    Int          @unique
  location  String
  status    LockerStatus @default(Available)
  member_id String?

  @@map("lockers")
}
