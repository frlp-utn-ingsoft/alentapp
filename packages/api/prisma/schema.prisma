// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

model Member {
    id          String         @id @default(uuid())
    dni         String         @unique
    name        String
    email       String         @unique
    birthdate   DateTime?      @db.Date
    category    MemberCategory
    status      MemberStatus   @default(Activo)
    created_at  DateTime       @default(now())
    disciplines Discipline[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
    lockers Locker[] // Validacion de la relación bidicreccional con 'locker'
}


// LOCKER
enum LockerStatus {
    Disponible
    Ocupado
    Mantenimiento
}

model Locker {
    id        String       @id @default(uuid()) // Identificador único universal (UUID)
    numero    Int          @unique // Número entero, único e indexado
    estado    LockerStatus @default(Disponible)
    ubicacion String //Cadena de texto
    member_id String?      // Clave foránea, nullable

    // Relación opcional con Member para mantener consistencia
    member    Member?      @relation(fields: [member_id], references: [id])

    @@map("lockers") // Para que en la DB la tabla se llame 'lockers' en minúscula
}
// LOCKER

model Discipline {
    id                   String    @id @default(uuid())
    motivo               String
    fechaInicio          DateTime
    fechaFin             DateTime
    esSuspensionTotal    Boolean   @default(true)
    motivoLevantamiento  String?
    memberId             String
    member               Member    @relation(fields: [memberId], references: [id])

    @@map("disciplines")
}


// Sport
model Sport {
    id                   String    @id @default(uuid())
    Nombre              String    @unique
    Cupo_maximo          Int
    Precio_adicional     Float
    Descripcion          String
    Require_certificado_medico Boolean  @default(false)

    @@map("sports")
}
