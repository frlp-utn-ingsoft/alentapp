// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    payments   Payment[]
    equipmentLoans EquipmentLoan[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}

enum LockerStatus {
  Available
  Occupied
  Maintenance
}

enum PaymentStatus {
    Pending
    Paid
    Canceled
}

model Payment {
    id           String        @id @default(uuid())
    amount       Float
    month        Int
    year         Int
    status       PaymentStatus @default(Pending)
    due_date     DateTime      @db.Date
    payment_date DateTime?     @db.Timestamp()
    member_id    String

    member       Member        @relation(fields: [member_id], references: [id])

    @@map("payments")
}

model Locker {
  id        String       @id @default(uuid())
  number    Int          @unique
  location  String
  status    LockerStatus @default(Available)
  member_id String?

  @@map("lockers")
}

enum LoanStatus {
    Loaned
    Returned
    Damaged
}

model EquipmentLoan {
    id       String     @id @default(uuid())
    itemName String
    status   LoanStatus @default(Loaned)
    loanDate DateTime   @default(now())
    dueDate  DateTime
    memberId String

    member   Member     @relation(fields: [memberId], references: [id])

    @@map("equipment_loans")
}