// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

model Member {
    id          String          @id @default(uuid()) @db.Uuid
    dni         String          @unique
    name        String
    email       String          @unique
    birthdate   DateTime?       @db.Date
    category    MemberCategory
    status      MemberStatus    @default(Activo)
    created_at  DateTime        @default(now())
    disciplines Discipline[]
    loans       EquipmentLoan[]
    lockers     Locker[]
    payments    Payment[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minuscula
}

model Discipline {
    id                  String   @id @default(uuid()) @db.Uuid
    reason              String
    start_date          DateTime
    end_date            DateTime
    is_total_suspension Boolean
    member_id           String   @db.Uuid
    member              Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

    @@index([member_id])
    @@map("disciplines")
}

enum LoanStatus {
    Loaned
    Returned
    Damaged
}

model EquipmentLoan {
    id        String     @id @default(uuid()) @db.Uuid
    member_id String     @db.Uuid
    item_name String
    loan_date DateTime
    due_date  DateTime
    status    LoanStatus @default(Loaned)
    member    Member     @relation(fields: [member_id], references: [id], onDelete: Cascade)

    @@index([member_id])
    @@map("equipment_loans")
}

model Sport {
    id                           String  @id @default(uuid()) @db.Uuid
    name                         String  @unique
    description                  String
    max_capacity                 Int
    current_enrollment_count     Int     @default(0)
    additional_price             Float
    requires_medical_certificate Boolean

    @@map("sports")
}

enum LockerStatus {
    Available
    Maintenance
    Occupied
}

model Locker {
    id          String          @id @default(uuid()) @db.Uuid       
    number      Int             @unique
    location    String      
    status      LockerStatus    @default(Available)
    member_id   String?         @db.Uuid
    member      Member?         @relation(fields: [member_id], references: [id])

    @@map("lockers")
}
   
enum PaymentStatus {
    Pending
    Paid
    Canceled
}

model Payment {
    id           String        @id @default(uuid()) @db.Uuid
    amount       Float
    month        Int
    year         Int
    status       PaymentStatus @default(Pending)
    due_date     DateTime      @db.Date
    payment_date DateTime?
    created_at   DateTime      @default(now())
    member_id    String        @db.Uuid
    member       Member        @relation(fields: [member_id], references: [id])

    @@index([member_id])
    @@map("payments")
}
