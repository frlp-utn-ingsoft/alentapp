// This is your Prisma schema file

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

model Member {
    id         String         @id @default(uuid()) @db.Uuid // 👈 Le agregamos @db.Uuid
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    
    // 👈 AGREGAR ESTA LÍNEA: Relación inversa para que Prisma compile feliz
    payments   Payment[]

    @@map("members")
}

model Payment {
  id           String    @id @default(uuid()) @db.Uuid
  amount       Float
  month        Int
  year         Int
  status       String    // Valores: "Pending", "Paid", "Canceled"
  due_date     DateTime  @db.Date
  payment_date DateTime? @db.Timestamp
  member_id    String    @db.Uuid
  
  // Relación con el modelo Member 
  member       Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@map("payments")
}