{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@alentapp/shared": ["./packages/shared/index.ts"]
        }
    },
    "include": ["packages/api/src/**/*.ts", "packages/shared/index.ts"],
    "exclude": ["node_modules"]
}
